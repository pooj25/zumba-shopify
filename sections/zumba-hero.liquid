<section class="hero">
  <div class="page-width">
    <div class="hero__content">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="hero__actions">
        <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="button button--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="hero__stats" aria-label="Class highlights">
        <div class="stat"><strong>{{ section.settings.stat_one }}</strong><span>{{ section.settings.stat_one_label }}</span></div>
        <div class="stat"><strong>{{ section.settings.stat_two }}</strong><span>{{ section.settings.stat_two_label }}</span></div>
        <div class="stat"><strong>{{ section.settings.stat_three }}</strong><span>{{ section.settings.stat_three_label }}</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zumba hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Dance fitness studio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Zumba That Moves You" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Book energetic Zumba classes, trial sessions, and monthly passes through a simple Shopify checkout." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Start with a trial" },
    { "type": "text", "id": "primary_link", "label": "Primary button link", "default": "#pricing" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "View schedule" },
    { "type": "text", "id": "secondary_link", "label": "Secondary button link", "default": "#schedule" },
    { "type": "text", "id": "stat_one", "label": "Stat one", "default": "45 min" },
    { "type": "text", "id": "stat_one_label", "label": "Stat one label", "default": "high energy classes" },
    { "type": "text", "id": "stat_two", "label": "Stat two", "default": "3 plans" },
    { "type": "text", "id": "stat_two_label", "label": "Stat two label", "default": "trial, pass, membership" },
    { "type": "text", "id": "stat_three", "label": "Stat three", "default": "All levels" },
    { "type": "text", "id": "stat_three_label", "label": "Stat three label", "default": "beginner friendly" }
  ],
  "presets": [{ "name": "Zumba hero" }]
}
{% endschema %}
