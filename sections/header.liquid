<header class="site-header">
  <div class="page-width site-header__inner">
    <a class="site-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <span class="brand-mark">Z</span>
      <span>{{ settings.brand_name | default: shop.name }}</span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href="#classes">Classes</a>
      <a href="#pricing">Pricing</a>
      <a href="#schedule">Schedule</a>
      <a href="#contact">Contact</a>
    </nav>

    <a class="button button--secondary" href="{{ section.settings.cta_link }}">
      {{ section.settings.cta_label }}
    </a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Book class" },
    { "type": "text", "id": "cta_link", "label": "Button link", "default": "#pricing" }
  ]
}
{% endschema %}
