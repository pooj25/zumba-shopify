<section id="classes" class="section section--white">
  <div class="page-width">
    <div class="section__head">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="feature-grid">
      {% for block in section.blocks %}
        <article class="feature" {{ block.shopify_attributes }}>
          <span class="feature__icon">{{ block.settings.icon }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zumba features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why join" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for real class bookings" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Sell class passes like products, guide students to the right plan, and keep your schedule clear on the home page." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Short icon text", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Trial class" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Let new students buy a single introductory class before choosing a plan." }
      ]
    }
  ],
  "presets": [{ "name": "Zumba features" }]
}
{% endschema %}
