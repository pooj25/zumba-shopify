<section id="contact" class="section">
  <div class="page-width">
    <div class="trainer-panel">
      <div class="trainer-art" aria-hidden="true"></div>
      <div class="trainer-copy">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
        <div class="contact-strip">
          <p>{{ section.settings.contact_text }}</p>
          <a class="button button--secondary" href="{{ section.settings.contact_link }}">{{ section.settings.contact_label }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trainer contact",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trainer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Led by a certified dance fitness coach" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use this space for trainer bio, studio location, WhatsApp details, and what beginners should bring to their first class." },
    { "type": "text", "id": "contact_text", "label": "Contact text", "default": "Questions before booking? Message the studio." },
    { "type": "text", "id": "contact_label", "label": "Contact label", "default": "WhatsApp us" },
    { "type": "text", "id": "contact_link", "label": "Contact link", "default": "https://wa.me/" }
  ],
  "presets": [{ "name": "Trainer contact" }]
}
{% endschema %}
